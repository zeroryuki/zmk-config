#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

#define BASE   0
#define NAV    1
#define SYM    2
#define MEDIA  3
#define NUMPAD 4
#define QWERTY 5

/ {
    behaviors {

        // в”Җв”Җ Tap-Dance в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        // TD(0): tap=;  double-tap=:
        td0: td_semi {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp SEMI>, <&kp COLON>;
        };

        // TD(3): tap=[  double-tap=[B (macro m4)
        td3: td_bracket {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp LBKT>, <&m4>;
        };

        // TD(6): tap=RGB_TOG  double-tap=RGB next-effect
        //td6: td_rgb {
        //    compatible = "zmk,behavior-tap-dance";
        //    #binding-cells = <0>;
        //    tapping-term-ms = <200>;
        //    bindings = <&rgb_ug RGB_TOG>, <&rgb_ug RGB_EFF>;
        //};

        // TD(8): tap=-  double-tap=_
        td8: td_minus {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp MINUS>, <&kp UNDER>;
        };

        // в”Җв”Җ Encoder sensor-rotate behaviors в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        //rgb_eff_enc: rgb_effect_encoder {
        //    compatible = "zmk,behavior-sensor-rotate";
        //    #sensor-binding-cells = <0>;
        //    bindings = <&rgb_ug RGB_EFF>, <&rgb_ug RGB_EFR>;
        //};
        //rgb_hue_enc: rgb_hue_encoder {
        //    compatible = "zmk,behavior-sensor-rotate";
        //    #sensor-binding-cells = <0>;
        //    bindings = <&rgb_ug RGB_HUI>, <&rgb_ug RGB_HUD>;
        //};
        //rgb_bri_enc: rgb_brightness_encoder {
        //    compatible = "zmk,behavior-sensor-rotate";
        //    #sensor-binding-cells = <0>;
        //    bindings = <&rgb_ug RGB_BRI>, <&rgb_ug RGB_BRD>;
        //};
        //rgb_sat_enc: rgb_saturation_encoder {
        //    compatible = "zmk,behavior-sensor-rotate";
        //    #sensor-binding-cells = <0>;
        //    bindings = <&rgb_ug RGB_SAI>, <&rgb_ug RGB_SAD>;
        //};
    };

    macros {
        // M0: Cmd+C (copy)
        m0: m_cmd_c {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(C)>;
        };
        // M1: Cmd+V (paste)
        m1: m_cmd_v {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(V)>;
        };
        // M2: Cmd+Shift+4 (screenshot area) вҖ” unbound, add to a layer as needed
        m2: m_screenshot {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LS(LG(N4))>;
        };
        // M3: Cmd+Space (Spotlight / Raycast) вҖ” unbound, add to a layer as needed
        m3: m_spotlight {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(SPACE)>;
        };
        // M4: type "[B"
        m4: m_lbkt_b {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LBKT &kp B>;
        };
    };

    combos {
        compatible = "zmk,combos";
        // MO(SYM) + SPACE held simultaneously вҶ’ MO(MEDIA)
        // Adjust key-positions to your board's left-thumb SYM and SPACE matrix indices
        combo_media {
            timeout-ms = <50>;
            key-positions = <34 35>;
            bindings = <&mo MEDIA>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
        // Layer 0 вҖ” BASE  (Colemak-DH)
        // в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
        // Left                               Right (outerвҶ’inner)
        // в”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”җ  в”Ңв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”¬в”Җв”Җв”Җв”җ
        // в”Ӯ ESC в”Ӯ Q в”Ӯ W в”Ӯ F в”Ӯ P в”Ӯ B в”Ӯ  в”Ӯ J в”Ӯ L в”Ӯ U в”Ӯ Y в”Ӯ;/:в”Ӯ-/_в”Ӯ
        // в”Ӯ TAB в”Ӯ A в”Ӯ R в”Ӯ S в”Ӯ T в”Ӯ G в”Ӯ  в”Ӯ M в”Ӯ N в”Ӯ E в”Ӯ I в”Ӯ O в”ӮENTв”Ӯ
        // в”ӮLALT в”Ӯ X в”Ӯ C в”Ӯ D в”Ӯ V в”Ӯ Z в”Ӯ  в”Ӯ K в”Ӯ H в”Ӯ , в”Ӯ . в”Ӯ / в”ӮBSPв”Ӯ
        // в””в”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”ҳ  в””в”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”јв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҳ
        //               в”ӮCTLв”ӮNAVв”ӮSYMв”Ӯ  в”ӮSPCв”ӮSFTв”ӮMEDв”Ӯ
        //               в””в”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҳ  в””в”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”ҳ
        base_layer {
            bindings = <
                // Left half (21 keys: 6 + 6 + 6 + 3)
                &kp ESC   &kp Q    &kp W    &kp F     &kp P     &kp B
                &kp TAB   &kp A    &kp R    &kp S     &kp T     &kp G
                &kp LALT  &kp X    &kp C    &kp D     &kp V     &kp Z
                                            &kp LCTRL &mo NAV   &mo SYM
                // Right half (21 keys: 6 + 6 + 6 + 3) вҖ” outer edge first
                &kp J     &kp L    &kp U    &kp Y     &td0      &td8
                &kp M     &kp N    &kp E    &kp I     &kp O     &kp RET
                &kp K     &kp H    &kp COMMA &kp DOT  &kp FSLH  &kp BSPC
                                            &kp SPACE &kp LSHFT &mo MEDIA
            >;
            sensor-bindings = <
                &rgb_eff_enc &rgb_hue_enc &rgb_bri_enc &rgb_sat_enc
            >;
        };

        // в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
        // Layer 1 вҖ” NAV + Numpad
        // в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
        nav_layer {
            bindings = <
                // Left half
                &td3              &none     &kp LG(W)     &kp RG(F)    &none         &none
                &kp LC(LS(LEFT))  &kp LG(A) &kp LG(R)     &none        &kp RG(T)     &kp LS(LG(T))
                &kp CAPS          &kp LALT  &none         &none        &kp LS(LG(V)) &kp QMARK
                                                          &kp LSHFT   &none         &kp SPACE
                // Right half вҖ” outer edge first
                &kp KP_N1  &kp KP_N2  &kp KP_N3  &kp KP_N0  &kp F8    &none
                &kp KP_N4  &kp KP_N5  &kp KP_N6  &none      &kp UP    &kp LC(LS(RIGHT))
                &kp KP_N7  &kp KP_N8  &kp KP_N9  &kp LEFT   &kp DOWN  &kp RIGHT
                                                  &kp RET    &kp LCTRL &kp RGUI
            >;
            sensor-bindings = <
                &rgb_eff_enc &rgb_hue_enc &rgb_bri_enc &rgb_sat_enc
            >;
        };

        // в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
        // Layer 2 вҖ” SYMBOLS
        // в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
        sym_layer {
            bindings = <
                // Left half
                &kp TAB    &kp EXCL  &kp AT    &kp HASH  &kp DLLR      &kp PRCNT
                &kp TILDE  &none     &none     &none     &kp LS(LG(T)) &none
                &kp GRAVE  &kp RG(Z) &kp LG(C) &none     &kp LG(V)     &kp LSHFT
                                               &kp LSHFT &trans         &trans
                // Right half вҖ” outer edge first
                &kp CARET  &kp AMPS  &kp STAR  &kp LPAR  &kp RPAR  &kp SQT
                &kp MINUS  &kp LBKT  &kp RBKT  &none     &none     &none
                &kp EQUAL  &kp BSLH  &kp FSLH  &none     &none     &none
                                               &kp RSHFT &trans    &trans
            >;
            sensor-bindings = <
                &rgb_eff_enc &rgb_hue_enc &rgb_bri_enc &rgb_sat_enc
            >;
        };

        // в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
        // Layer 3 вҖ” MEDIA / Window Management
        // в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
        media_layer {
            bindings = <
                // Left half
                &bootloader &none  &none  &kp C_PREV           &kp C_PP             &kp C_NEXT
                &none       &none  &none  &none                &none                &none
                &mo QWERTY  &none  &none  &kp LC(LA(LG(H)))    &kp LC(LA(LG(DOWN))) &kp LC(LA(LG(UP)))
                                         &none                &trans               &kp SPACE
                // Right half вҖ” outer edge first
                &none  &none  &kp LC(N1)  &kp LC(N2)   &kp LC(N3)   &kp LC(N4)
                &none  &none  &kp LC(N5)  &kp LC(N6)   &kp LC(N7)   &kp LC(N8)
                &none  &msc SCRL_UP  &msc SCRL_DOWN  &none  &none  &none
                                               &kp RET  &trans  &trans
            >;
            sensor-bindings = <
                &rgb_eff_enc &rgb_hue_enc &rgb_bri_enc &rgb_sat_enc
            >;
        };

        // в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
        // Layer 4 вҖ” NUMPAD (left: transparent, right: numpad)
        // в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
        numpad_layer {
            bindings = <
                // Left half вҖ” all transparent
                &trans &trans &trans &trans &trans &trans
                &trans &trans &trans &trans &trans &trans
                &trans &trans &trans &trans &trans &trans
                                     &trans &trans &trans
                // Right half вҖ” outer edge first
                &trans  &trans  &kp KP_N1  &kp KP_N2  &kp KP_N3  &kp KP_N0
                &trans  &trans  &kp KP_N4  &kp KP_N5  &kp KP_N6  &trans
                &trans  &trans  &kp KP_N7  &kp KP_N8  &kp KP_N9  &trans
                                               &trans      &trans     &trans
            >;
        };

        // в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
        // Layer 5 вҖ” QWERTY
        // Hold MEDIA layer bottom-left вҶ’ activates this layer
        // Right thumb center: &tog QWERTY to lock/unlock
        // в”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғ
        qwerty_layer {
            bindings = <
                // Left half
                &trans &kp Q &kp W &kp E &kp R &kp T
                &trans &kp A &kp S &kp D &kp F &kp G
                &trans &kp Z &kp X &kp C &kp V &kp B
                                    &trans &trans &trans
                // Right half вҖ” outer edge first
                &kp Y   &kp U    &kp I     &kp O    &kp P    &trans
                &kp H   &kp J    &kp K     &kp L    &kp SEMI &kp SQT
                &kp N   &kp M    &kp COMMA &kp DOT  &kp FSLH &trans
                                           &trans   &tog QWERTY  &trans
            >;
        };
    };
};
