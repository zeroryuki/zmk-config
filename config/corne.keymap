#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

#define BASE   0
#define NAV    1
#define SYM    2
#define MEDIA  3
#define NUMPAD 4
#define QWERTY 5

/ {
    behaviors {

        // ── Tap-Dance ──────────────────────────────────────────────
        // TD(0): tap=;  double-tap=:
        td0: td_semi {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp SEMI>, <&kp COLON>;
        };

        // TD(3): tap=[  double-tap=[B (macro m4)
        td3: td_bracket {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp LBKT>, <&m4>;
        };

        // TD(8): tap=-  double-tap=_
        td8: td_minus {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp MINUS>, <&kp UNDER>;
        };

    };

    macros {
        // M0: Cmd+C (copy)
        m0: m_cmd_c {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(C)>;
        };
        // M1: Cmd+V (paste)
        m1: m_cmd_v {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(V)>;
        };
        // M2: Cmd+Shift+4 (screenshot area) — unbound, add to a layer as needed
        m2: m_screenshot {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LS(LG(N4))>;
        };
        // M3: Cmd+Space (Spotlight / Raycast) — unbound, add to a layer as needed
        m3: m_spotlight {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(SPACE)>;
        };
        // M4: type "[B"
        m4: m_lbkt_b {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LBKT &kp B>;
        };
    };

    combos {
        compatible = "zmk,combos";
        // MO(SYM) + SPACE held simultaneously → MO(MEDIA)
        // Corne positions: 38 = left thumb SYM (LT2), 39 = right thumb SPACE (RT0)
        combo_media {
            timeout-ms = <50>;
            key-positions = <38 39>;
            bindings = <&mo MEDIA>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Layer 0 — BASE  (Colemak-DH)
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // ┌─────┬───┬───┬───┬───┬───┐  ┌───┬───┬───┬───┬───┬───┐
        // │ ESC │ Q │ W │ F │ P │ B │  │ J │ L │ U │ Y │;/:│-/_│
        // │ TAB │ A │ R │ S │ T │ G │  │ M │ N │ E │ I │ O │ENT│
        // │LALT │ X │ C │ D │ V │ Z │  │ K │ H │ , │ . │ / │BSP│
        // └─────┴───┴───┼───┼───┼───┘  └───┼───┼───┼───┴───┴───┘
        //               │CTL│NAV│SYM│  │SPC│SFT│MED│
        //               └───┴───┴───┘  └───┴───┴───┘
        base_layer {
            bindings = <
                &kp ESC   &kp Q    &kp W    &kp F     &kp P     &kp B      &kp J     &kp L    &kp U     &kp Y    &td0      &td8
                &kp TAB   &kp A    &kp R    &kp S     &kp T     &kp G      &kp M     &kp N    &kp E     &kp I    &kp O     &kp RET
                &kp LALT  &kp X    &kp C    &kp D     &kp V     &kp Z      &kp K     &kp H    &kp COMMA &kp DOT  &kp FSLH  &kp BSPC
                                            &kp LCTRL &mo NAV   &mo SYM    &kp SPACE &kp LSHFT &mo MEDIA
            >;
        };

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Layer 1 — NAV + Numpad
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        nav_layer {
            bindings = <
                &td3             &none     &kp LG(W)  &kp RG(F) &none         &none          &kp KP_N1 &kp KP_N2 &kp KP_N3 &kp KP_N0 &kp F8           &none
                &kp LC(LS(LEFT)) &kp LG(A) &kp LG(R)  &none     &kp RG(T)     &kp LS(LG(T))  &kp KP_N4 &kp KP_N5 &kp KP_N6 &none     &kp UP           &kp LC(LS(RIGHT))
                &kp CAPS         &kp LALT  &none      &none     &kp LS(LG(V)) &kp QMARK      &kp KP_N7 &kp KP_N8 &kp KP_N9 &kp LEFT  &kp DOWN         &kp RIGHT
                                                      &kp LSHFT &none         &kp SPACE      &kp RET   &kp LCTRL &kp RGUI
            >;
        };

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Layer 2 — SYMBOLS
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        sym_layer {
            bindings = <
                &kp TAB    &kp EXCL  &kp AT    &kp HASH  &kp DLLR      &kp PRCNT   &kp CARET &kp AMPS &kp STAR &kp LPAR &kp RPAR &kp SQT
                &kp TILDE  &none     &none     &none     &kp LS(LG(T)) &none        &kp MINUS &kp LBKT &kp RBKT &none    &none    &none
                &kp GRAVE  &kp RG(Z) &kp LG(C) &none     &kp LG(V)     &kp LSHFT   &kp EQUAL &kp BSLH &kp FSLH &none    &none    &none
                                                          &kp LSHFT     &trans       &trans    &kp RSHFT &trans  &trans
            >;
        };

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Layer 3 — MEDIA / Window Management
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        media_layer {
            bindings = <
                &bootloader   &none         &none      &kp C_PREV        &kp C_PP             &kp C_NEXT         &none &none &kp LC(N1) &kp LC(N2) &kp LC(N3) &kp LC(N4)
                &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_CLR &none             &none                &none              &none &none &kp LC(N5) &kp LC(N6) &kp LC(N7) &kp LC(N8)
                &mo QWERTY    &none         &none      &kp LC(LA(LG(H))) &kp LC(LA(LG(DOWN))) &kp LC(LA(LG(UP))) &none &none &none      &none      &none      &none
                                                                          &none                &trans             &kp SPACE &kp RET &trans &trans
            >;
        };

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Layer 4 — NUMPAD (left: transparent, right: numpad)
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        numpad_layer {
            bindings = <
                &trans &trans &trans &trans &trans &trans   &trans &trans &kp KP_N1 &kp KP_N2 &kp KP_N3 &kp KP_N0
                &trans &trans &trans &trans &trans &trans   &trans &trans &kp KP_N4 &kp KP_N5 &kp KP_N6 &trans
                &trans &trans &trans &trans &trans &trans   &trans &trans &kp KP_N7 &kp KP_N8 &kp KP_N9 &trans
                                           &trans &trans   &trans &trans &trans    &trans
            >;
        };

        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        // Layer 5 — QWERTY
        // Hold MEDIA layer bottom-left → activates this layer
        // Right thumb center: &tog QWERTY to lock/unlock
        // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
        qwerty_layer {
            bindings = <
                &trans &kp Q &kp W &kp E &kp R &kp T   &kp Y &kp U    &kp I     &kp O    &kp P    &trans
                &trans &kp A &kp S &kp D &kp F &kp G   &kp H &kp J    &kp K     &kp L    &kp SEMI &kp SQT
                &trans &kp Z &kp X &kp C &kp V &kp B   &kp N &kp M    &kp COMMA &kp DOT  &kp FSLH &trans
                                   &trans &trans &trans  &trans &tog QWERTY &trans
            >;
        };
    };
};
